# Binaries / build
bin/
*.test
*.out
coverage.out
coverage.html

# Local release / audit artifacts (regenerate via scripts/)
artifacts/

# Local env (keep .env.example public)
.env
.env.*
!.env.example

# Database files and local runtime data (keep seed assets for Docker/runtime)
*.db
*.db-*
data/*
!data/csv/
!data/csv/**
!data/json/
!data/json/**

# Backups / logs / uploads
*.db.bak
*_backup_*.db
backups/
logs/
uploads_atividades/

# Secrets / keys / IDE / local tooling
*.pem
*.key
.cursor/
.idea/
.vscode/
go.work
go.work.sum

# Local-only material — kept on disk, never published to the public repo
# (exclude from remote package; do NOT delete locally)
# IMPORTANT: leading slash = repository root only (must not match cmd/api)
/docs/
/api/
/frontend_lab/

# Real Garmin device exports (may contain GPS/PII) — keep local only.
# Synthetic CI fixtures (synthetic_*.fit) are tracked.
/internal/garmin/testdata/fit/*_ACTIVITY.fit
/internal/garmin/testdata/fit/[0-9]_*.fit
